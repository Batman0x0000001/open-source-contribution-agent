# Required: Anthropic API Key for AI agent operations
ANTHROPIC_API_KEY=

# Optional: Use alternative Anthropic-compatible API endpoint (e.g., DeepSeek)
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# Optional: Model configuration
MODEL_ID=deepseek-v4-pro
FALLBACK_MODEL_ID=

# IMPORTANT: GitHub Personal Access Token
# Without token: 60 API requests/hour (easily exceeded)
# With token: 5,000 API requests/hour
# Get your token at: https://github.com/settings/tokens
# Permissions needed: None (public_repo read access is default)
GITHUB_TOKEN=

# Agent behavior limits
OSC_AGENT_MAX_ROUNDS=30
OSC_AGENT_MAX_TOKENS=200000
OSC_AGENT_DEADLINE_SECONDS=1800
OSC_AGENT_REPEAT_ACTION_LIMIT=3
OSC_AGENT_FAILURE_LIMIT=3
OSC_AGENT_NO_PROGRESS_LIMIT=6
OSC_AGENT_MAX_CHANGED_FILES=5
OSC_AGENT_MAX_DIFF_LINES=400
